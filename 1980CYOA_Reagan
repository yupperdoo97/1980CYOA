function buildVpTableHistorical() {
  return {
    "adlai stevenson": "John Sparkman",
    "dwight eisenhower": "Richard Nixon",
    "other candidates": "Various",
    "undecided": "N/A",
    "unpledged electors": "N/A"
  };
