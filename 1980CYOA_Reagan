    hqDiv.style.backgroundPosition = 'center';
    hqDiv.style.border = '1px solid black';
    hqDiv.style.borderRadius = '10px';
    hqDiv.style.height = '50%';
    hqDiv.style.padding = '5px';
    hqDiv.style.margin = '0px 0px 10px 0px';
    hqDiv.style.position = 'relative';

    // Header
    let headerDiv = document.createElement('div');
    headerDiv.style.display = 'flex';
    headerDiv.style.justifyContent = 'space-between';
    headerDiv.style.alignItems = 'center';
    headerDiv.style.width = '100%';

    let backButton = document.createElement('button');
    backButton.innerText = 'Back';
    backButton.style.margin = '5px';
    backButton.onclick = function() {
        hqDiv.remove();
        questions.style.display = '';
    };
    headerDiv.appendChild(backButton);

    let headerText = document.createElement('h3');
    headerText.textContent = 'DNC HQ';
    headerText.style.color = 'black';
    headerText.style.textAlign = 'center';
    headerText.style.marginLeft = '90px';
    headerText.style.marginTop = '5px';
    headerText.style.flexGrow = '1';
    headerText.style.position = 'relative';
    headerText.style.zIndex = '10';
    headerText.style.fontSize = '23px';
    headerText.style.textDecoration = 'underline';
    headerDiv.appendChild(headerText);

    hqDiv.appendChild(headerDiv);

    // --- Notebook container with attached text ---
    let notebookContainer = document.createElement('div');
    notebookContainer.style.position = 'relative';
    notebookContainer.style.display = 'inline-block';
    notebookContainer.style.marginTop = '-40px'; // moved higher

    let notebookImg = document.createElement('img');
    notebookImg.src = 'https://imgur.com/o2nc7FX.png';
    notebookImg.style.height = '325px';
    notebookImg.style.zIndex = '1';
    notebookImg.style.marginTop = '-25px';
    notebookContainer.appendChild(notebookImg);

    notebookImg.style.filter = `
      drop-shadow(-4px 6px 6px rgba(0, 0, 0, 0.5))
      drop-shadow(-8px 14px 18px rgba(0, 0, 0, 0.5))
    `;

    let notebookText = document.createElement('div');
    notebookText.style.position = 'absolute';
    notebookText.style.top = '20px'; // moved text up
    notebookText.style.left = '45px';
    notebookText.style.textAlign = 'left';
    notebookText.style.color = 'black';
    notebookText.style.fontSize = '14px';
    notebookText.style.pointerEvents = 'none';
    notebookText.style.paddingRight = '10px';

    // Updated addLine to accept full margin
    function addLine(text, margin = '0px') {
        let line = document.createElement('div');
        line.textContent = text;
        line.style.lineHeight = '1.1';        // single spacing
        line.style.margin = margin;         // use full margin shorthand
        line.style.padding = '0';
        line.style.fontStyle = 'italic';
        notebookText.appendChild(line);
    }

    // Populate notebook text with custom spacing
    addLine('The insurgents have ' + campaignVars.left + ' wins in key areas.', '12px 0px 0px 0px'); // first line custom
    addLine('Organized labor has ' + campaignVars.labor + ' strategic victories secured.', '18px 0px 0px 0px');
