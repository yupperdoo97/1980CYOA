// Get VP safely
function getVP(name, table) {
  const clean = normalizeName(name);

  // Direct match
  if (table.hasOwnProperty(clean)) {
    return table[clean];
  }

  // N/A categories
  if (clean === "undecided" || clean === "unpledged" || clean === "unpledged electors") {
    return "N/A";
  }

  // Everything else - various
  return "Various";
}

